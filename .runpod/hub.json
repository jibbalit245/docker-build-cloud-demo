{
  "title": "Omni-Stack: Multi-Model AI",
  "description": "Unified AI stack serving Qwen3-Next-80B, Qwen2.5-VL-32B (vision), Lilith-Whisper-70B, and Wan2.2 (video generation) through a single OpenAI-compatible gateway.",
  "type": "serverless",
  "category": "language",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 50,
    "gpuCount": 7,
    "gpuIds": "AMPERE_80",
    "allowedCudaVersions": [
      "12.4",
      "12.3",
      "12.2",
      "12.1",
      "12.0"
    ],
    "presets": [
      {
          "name": "Qwen3-80B Text (3x RTX Pro 6000)",
          "defaults": {
            "VLLM_MODEL": "huihui-ai/Huihui-Qwen3-Next-80B-A3B-Instruct-abliterated",
            "TENSOR_PARALLEL": "3",
            "GPU_MEMORY_UTILIZATION": "0.85"
          }
        },
        {
          "name": "Vision + Text + Video (RTX Pro 6000 split)",
          "defaults": {
            "VLLM_MODEL": "huihui-ai/Huihui-Qwen3-Next-80B-A3B-Instruct-abliterated",
            "TENSOR_PARALLEL": "3",
            "GPU_MEMORY_UTILIZATION": "0.45"
          }
        }
    ],
    "env": [
      {
        "key": "HF_HOME",
        "value": "/workspace/hf_cache"
      },
      {
        "key": "OLLAMA_MODELS",
        "value": "/workspace/ollama_models"
      },
      {
        "key": "OLLAMA_HOST",
        "value": "0.0.0.0:11434"
      },
      {
        "key": "OLLAMA_MODEL_NAME",
        "value": "hf.co/bartowski/Liliths-Whisper-L3.3-70b-0.2a.i1-Q4_K_M-GGUF:latest"
      },
      {
        "key": "OLLAMA_MODEL_CANDIDATES",
        "value": "hf.co/bartowski/Liliths-Whisper-L3.3-70b-0.1.Q4_K_M-GGUF:latest,hf.co/bartowski/Liliths-Whisper-L3.3-70b-0.2a.i1-Q4_K_M-GGUF:latest"
      },
      {
        "key": "FORCE_SYNTHETIC_SSE",
        "value": "true"
      },
      {
        "key": "HF_TOKEN",
        "input": {
          "name": "HuggingFace Token",
          "type": "string",
          "description": "Your HuggingFace access token for downloading models",
          "default": "",
          "advanced": false
        }
      },
      {
        "key": "VLLM_MODEL",
        "input": {
          "name": "Primary LLM",
          "type": "string",
          "description": "HuggingFace model ID for the primary text model (served via vLLM)",
          "default": "huihui-ai/Huihui-Qwen3-Next-80B-A3B-Instruct-abliterated",
          "advanced": false
        }
      },
      {
        "key": "TENSOR_PARALLEL",
        "input": {
          "name": "Tensor Parallel Size",
          "type": "number",
          "description": "Number of GPUs to split the model across",
          "min": 1,
          "max": 8,
          "default": 3
        }
      },
      {
        "key": "VLLM_CUDA_DEVICES",
        "value": "0,1,2"
      },
      {
        "key": "VL_CUDA_DEVICES",
        "value": "3,4"
      },
      {
        "key": "WAN_CUDA_DEVICES",
        "value": "5,6"
      },
      {
        "key": "GPU_MEMORY_UTILIZATION",
        "input": {
          "name": "GPU Memory Utilization",
          "type": "string",
          "description": "Fraction of GPU memory to use for vLLM (0.0-0.95)",
          "default": "0.85",
          "advanced": true
        }
      }
    ]
  }
}
