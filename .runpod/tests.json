{
  "tests": [
    {
      "name": "text_chat",
      "input": {
        "type": "chat",
        "model": "qwen3-80b",
        "prompt": "Say hello in one sentence.",
        "max_tokens": 64
      },
      "timeout": 120000
    },
    {
      "name": "lilith_chat",
      "input": {
        "type": "chat",
        "model": "lilith",
        "prompt": "Say hello in one sentence.",
        "max_tokens": 64
      },
      "timeout": 120000
    },
    {
      "name": "vision_chat",
      "input": {
        "type": "chat",
        "model": "vision",
        "prompt": "Say hello in one sentence.",
        "max_tokens": 64
      },
      "timeout": 120000
    },
    {
      "name": "wan_video_generate",
      "input": {
        "type": "video",
        "model": "wan2.2",
        "prompt": "A short clip of waves hitting a beach at sunset.",
        "num_frames": 16
      },
      "timeout": 600000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA RTX Pro 6000",
    "gpuCount": 7,
    "allowedCudaVersions": [
      "12.4",
      "12.3",
      "12.2",
      "12.1",
      "12.0"
    ],
    "env": [
      {
        "key": "HF_HOME",
        "value": "/workspace/hf_cache"
      },
      {
        "key": "OLLAMA_MODELS",
        "value": "/workspace/ollama_models"
      },
      {
        "key": "TENSOR_PARALLEL",
        "value": "3"
      },
      {
        "key": "GPU_MEMORY_UTILIZATION",
        "value": "0.85"
      },
      {
        "key": "VLLM_CUDA_DEVICES",
        "value": "0,1,2"
      },
      {
        "key": "VL_CUDA_DEVICES",
        "value": "3,4"
      },
      {
        "key": "WAN_CUDA_DEVICES",
        "value": "5,6"
      }
    ]
  }
}
